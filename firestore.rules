rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // users/{userId}/workLogs/{dateId}
    //   ownerUid: string, immutable, authenticated owner UID
    //   date: string, immutable, YYYY-MM-DD and equal to dateId
    //   payload: string, JSON, 1..50,000 chars
    //   updatedAt: timestamp, server request time
    // users/{userId}/events/{eventId} (legacy owner-scoped events)
    //   ownerUid: string, immutable, authenticated owner UID
    //   id: string, immutable and equal to eventId
    //   payload: string, JSON, 1..50,000 chars
    //   updatedAt: timestamp, server request time
    // sharedEvents/{eventId} (public team Event data)
    //   id: string, immutable and equal to eventId
    //   payload: string, JSON, 1..50,000 chars
    //   updatedAt: timestamp, server request time
    // sharedAppData/team (public team application state)
    //   id: string, immutable, exactly "team"
    //   payload: string, JSON, 2..500,000 chars
    //   updatedAt: timestamp, server request time
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Access-code based roles (requester/approver/admin). The custom token is
    // minted by the verifyAccessCode Cloud Function only after a valid,
    // active 4-digit code is checked server-side - this is not something a
    // client can fake, since request.auth.token comes from a verified JWT.
    function hasAnyRole() {
      return isAuthenticated() &&
        request.auth.token.role in ['requester', 'approver', 'admin'];
    }

    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    function uidUnchanged(userId) {
      return request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.ownerUid == userId;
    }

    function uidNotModified() {
      return request.resource.data.ownerUid == resource.data.ownerUid;
    }

    function isValidWorkLog(data, userId, dateId) {
      return data.keys().hasAll(['ownerUid', 'date', 'payload', 'updatedAt']) &&
        data.keys().hasOnly(['ownerUid', 'date', 'payload', 'updatedAt']) &&
        data.ownerUid is string &&
        data.ownerUid.size() > 0 &&
        data.ownerUid.size() <= 128 &&
        data.ownerUid == userId &&
        data.date is string &&
        data.date.size() == 10 &&
        data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
        data.date == dateId &&
        data.payload is string &&
        data.payload.size() > 0 &&
        data.payload.size() <= 50000 &&
        data.updatedAt is timestamp &&
        data.updatedAt == request.time;
    }

    function isValidEvent(data, userId, eventId) {
      return data.keys().hasAll(['ownerUid', 'id', 'payload', 'updatedAt']) &&
        data.keys().hasOnly(['ownerUid', 'id', 'payload', 'updatedAt']) &&
        data.ownerUid is string &&
        data.ownerUid.size() > 0 &&
        data.ownerUid.size() <= 128 &&
        data.ownerUid == userId &&
        data.id is string &&
        data.id.size() > 0 &&
        data.id.size() <= 120 &&
        data.id == eventId &&
        data.payload is string &&
        data.payload.size() > 0 &&
        data.payload.size() <= 50000 &&
        data.updatedAt is timestamp &&
        data.updatedAt == request.time;
    }

    function isValidSharedEvent(data, eventId) {
      return data.keys().hasAll(['id', 'payload', 'updatedAt']) &&
        data.keys().hasOnly(['id', 'payload', 'updatedAt']) &&
        data.id is string &&
        data.id.size() > 0 &&
        data.id.size() <= 120 &&
        data.id == eventId &&
        data.payload is string &&
        data.payload.size() > 0 &&
        data.payload.size() <= 50000 &&
        data.updatedAt is timestamp &&
        data.updatedAt == request.time;
    }

    function isValidSharedAppData(data, stateId) {
      return data.keys().hasAll(['id', 'payload', 'updatedAt']) &&
        data.keys().hasOnly(['id', 'payload', 'updatedAt']) &&
        stateId == 'team' &&
        data.id is string &&
        data.id == stateId &&
        data.payload is string &&
        data.payload.size() >= 2 &&
        data.payload.size() <= 500000 &&
        data.updatedAt is timestamp &&
        data.updatedAt == request.time;
    }

    match /users/{userId}/workLogs/{dateId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && uidUnchanged(userId) &&
        isValidWorkLog(request.resource.data, userId, dateId);
      allow update: if isOwner(userId) && uidUnchanged(userId) &&
        uidNotModified() && request.resource.data.date == resource.data.date &&
        isValidWorkLog(request.resource.data, userId, dateId);
      allow delete: if isOwner(userId) && resource.data.ownerUid == request.auth.uid;
    }

    match /users/{userId}/events/{eventId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && uidUnchanged(userId) &&
        isValidEvent(request.resource.data, userId, eventId);
      allow update: if isOwner(userId) && uidUnchanged(userId) && uidNotModified() &&
        request.resource.data.id == resource.data.id &&
        isValidEvent(request.resource.data, userId, eventId);
      allow delete: if isOwner(userId) && resource.data.ownerUid == request.auth.uid;
    }

    // TEMPORARY: opened back up so the team can use shared data (Event
    // calendar, team app state) while the 4-digit code login is disabled on
    // the client (no real Firebase Auth session exists yet, so hasAnyRole()
    // would block everyone). Restore the hasAnyRole() checks above once
    // `firebase deploy --only functions` succeeds and the code gate is
    // switched back on in index.html.
    match /sharedEvents/{eventId} {
      allow read: if true;
      allow create: if isValidSharedEvent(request.resource.data, eventId);
      allow update: if request.resource.data.id == resource.data.id &&
        isValidSharedEvent(request.resource.data, eventId);
      allow delete: if false;
    }

    match /sharedAppData/{stateId} {
      allow read: if stateId == 'team';
      allow create: if isValidSharedAppData(request.resource.data, stateId);
      allow update: if request.resource.data.id == resource.data.id &&
        isValidSharedAppData(request.resource.data, stateId);
      allow delete: if false;
    }

    // Access codes: {code} -> {name, role, active, createdAt, lastUsedAt}
    // Only an already-authenticated admin can list/create/edit/delete codes
    // through the app UI. The verifyAccessCode Cloud Function reads this
    // collection with the Admin SDK, which bypasses these rules entirely,
    // so a brand-new (not-yet-signed-in) person can still redeem a code.
    match /codeAttempts/{ip} {
      allow read, write: if false;
    }

    match /accessCodes/{code} {
      allow read, write: if hasRole('admin');
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
